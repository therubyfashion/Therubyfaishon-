{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "phoneVerified": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Address": {
      "title": "Address",
      "description": "User shipping address.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "number": { "type": "string" },
        "address": { "type": "string" },
        "landmark": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "pincode": { "type": "string" },
        "label": { "type": "string", "enum": ["Home", "Office", "Other"] },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "number", "address", "state", "city", "pincode", "label"]
    },
    "Product": {
      "title": "Product",
      "description": "Clothing item details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Men", "Women", "New Arrivals"] },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "shippingMethod": { "type": "string", "enum": ["standard", "express", "economy"], "description": "Method of shipping chosen by the customer.", "default": "standard" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Color": {
      "title": "Color",
      "description": "Product color option.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hex": { "type": "string" }
      },
      "required": ["name", "hex"]
    },
    "Size": {
      "title": "Size",
      "description": "Product size option.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "integer" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discount"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Marketing banner.",
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["image", "title"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "userImage": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "integer" }
      },
      "required": ["productId", "userName", "userEmail", "rating", "comment"]
    },
    "Cart": {
      "title": "Cart",
      "description": "Shopping cart for abandoned cart recovery.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "converted", "abandoned"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "totalAmount", "status"]
    },
    "ActiveSession": {
      "title": "ActiveSession",
      "description": "Live visitor session tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "path": { "type": "string" }
      },
      "required": ["id", "lastSeen"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Push notification history.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["all", "active", "new"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "sentBy": { "type": "string", "format": "email" },
        "status": { "type": "string" }
      },
      "required": ["title", "body", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/users/{uid}/addresses/{addressId}": { "schema": "Address", "description": "User saved addresses" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/colors/{colorId}": { "schema": "Color", "description": "Product colors" },
    "/sizes/{sizeId}": { "schema": "Size", "description": "Product sizes" },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Discount coupons" },
    "/banners/{bannerId}": { "schema": "Banner", "description": "Marketing banners" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Product reviews" },
    "/carts/{cartId}": { "schema": "Cart", "description": "Shopping carts" },
    "/settings/{settingId}": { "schema": "object", "description": "Global store settings" },
    "/active_sessions/{sessionId}": { "schema": "ActiveSession", "description": "Live visitor sessions" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Push notification history" }
  }
}
